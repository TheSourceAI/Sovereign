# ── Claude API ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase ────────────────────────────────────────────────
# Backend agents use the SERVICE key (full access).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Dashboard (browser) uses the ANON key. These go in dashboard/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Scheduler ───────────────────────────────────────────────
CYCLE_MINUTES=30

# ── Vapi (voice) ────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_URL=https://your-dashboard-domain.com/api/vapi
